{
  "response_format": {
    "type": "json_schema",
    "json_schema": {
      "name": "weather",
      "strict": true,
      "schema": {
        "type": "object",
        "properties": {
          "conditions": {
            "type": "string",
            "description": "Weather conditions description"
          },
          "location": {
            "type": "string",
            "description": "City or location name"
          },
          "temperature": {
            "type": "number",
            "description": "Temperature in Celsius"
          }
        },
        "required": ["conditions", "location", "temperature"],
        "additionalProperties": false
      }
    }
  }
}
